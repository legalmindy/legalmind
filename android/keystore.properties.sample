# Copy this file to android/keystore.properties (which is gitignored) and fill in real values
# to enable signed release builds (npm run build:android:release / :aab).
#
# Generate a keystore once with:
#   keytool -genkeypair -v -keystore release-key.jks -alias legalmind -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is resolved relative to the android/ directory.
storeFile=release-key.jks
storePassword=CHANGE_ME
keyAlias=legalmind
keyPassword=CHANGE_ME
